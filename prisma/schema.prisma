generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  login           String   @unique
  password        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  personalBudgets PersonalBudget[]
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  unit        String   @default("szt.")
  priceNet    Float
  vatRate     Float    @default(23) // np. 23, 8, 0
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id               String        @id @default(cuid())
  type             String        @default("sales") // "cost" = faktura kosztowa, "sales" = faktura sprzedaży
  number           String        @unique
  issueDate        DateTime
  saleDate         DateTime?
  sellerName       String
  sellerNip        String
  buyerName        String
  buyerNip         String
  netAmount        Float
  vatAmount        Float
  grossAmount      Float
  currency         String        @default("PLN")
  paymentDueDate   DateTime?     // termin płatności (przypomnienie e-mail w ten dzień)
  recurringCode    String?       // np. zus, pit5, vat7 – rozrachunek cykliczny
  ksefSentAt       DateTime?
  ksefId           String?
  ksefStatus       String?
  source           String        @default("manual") // manual | ksef | mail | recurring
  handedOverToAccountant Boolean @default(false) // przekazane księgowej (tylko dla rozrachunków nie z KSeF)
  emailSubject     String?       // temat maila (dla source=mail)
  emailBody        String?       @db.Text // treść wiadomości
  emailFrom        String?       // nadawca
  emailReceivedAt  DateTime?     // data otrzymania
  emailMessageId   String?       // Message-ID do deduplikacji
  vatDeductionPercent  Float?    // udział VAT do odliczenia (1.0 = 100%, 0.5 = 50%) – moduł korzyści podatkowych
  costDeductionPercent Float?    // udział kosztu do odliczenia (1.0 = 100%, 0.75 = 75%)
  expenseType         String    @default("standard") // "standard" | "car" – typ wydatku (faktury zakupu)
  carId               String?   // powiązany samochód gdy expenseType = "car"
  includedInCosts     Boolean   @default(false) // ujęta w kosztach – liczy korzyść; nieujęta – korzyść 0
  remarks             String?   @db.Text // uwagi – opis dokumentu (faktury zakupu, rozrachunki)
  expenseCategoryId   String?   // kategoria kosztu (tylko faktury zakupu)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  payment          Payment?
  car               Car?         @relation(fields: [carId], references: [id], onDelete: SetNull)
  expenseCategory   ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id], onDelete: SetNull)
  items            InvoiceItem[]
  emailAttachments InvoiceEmailAttachment[]
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    // np. "Biuro", "Marketing", "Usługi IT"
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  invoices  Invoice[]
}

model Car {
  id                  String    @id @default(cuid())
  name                String    // np. "Skoda Octavia"
  value               Float     // wartość w PLN (do ustalenia progu limitu)
  limit100k           Float     @default(100000)  // limit odliczenia przy wartości do 100 tys. PLN
  limit150k           Float     @default(150000)  // limit przy 100–150 tys.
  limit200k           Float     @default(200000) // limit przy pow. 150 tys.
  vatDeductionPercent Float     @default(0.5)     // 0.5 = 50%, 1 = 100% VAT do odliczenia
  sortOrder           Int       @default(0)      // kolejność na liście
  createdAt           DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  invoices           Invoice[]
}

model RecurringSettlement {
  id         String   @id @default(cuid())
  code       String   @unique // zus, pit5, vat7
  name       String   // ZUS, PIT-5, VAT-7
  formName   String   @default("") // formularz: ok, VAT-7, PIT-5 (nazewnictwo: ZUS - ok, US - VAT-7, US - PIT-5)
  sellerName String   @default("") // np. "Zakład Ubezpieczeń Społecznych"
  sellerNip  String   @default("") // NIP wystawcy / odbiorcy (opcjonalnie)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model InvoiceEmailAttachment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  filename    String
  contentType String   @default("application/octet-stream")
  size        Int      @default(0)
  storedPath  String   // ścieżka do pliku na dysku (używana przy self-hosting); na Vercel ignorowana
  content     Bytes?   // treść pliku w DB – działa na hostingu bez trwałego dysku (np. Vercel)
  createdAt   DateTime @default(now())
}

model InvoiceItem {
  id           String   @id @default(cuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId    String?
  name         String
  quantity     Float    @default(1)
  unit         String   @default("szt.")
  unitPriceNet Float
  vatRate      Float    @default(23)
  amountNet    Float
  amountVat    Float
}

model Payment {
  id         String   @id @default(cuid())
  invoiceId  String   @unique
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paidAt     DateTime
  createdAt  DateTime @default(now())
}

model Contractor {
  id         String   @id @default(cuid())
  name       String
  nip        String
  address    String?
  postalCode String?
  city       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Message-ID maili, z których faktura została już pobrana i usunięta – nie pobierać ponownie.
model DeletedMailInvoiceMessageId {
  id             String   @id @default(cuid())
  emailMessageId String   @unique
  createdAt      DateTime @default(now())
}

// Moduł budżetu wzorowany na YNAB
model BudgetCategory {
  id          String   @id @default(cuid())
  name        String   // np. "Transport", "Jedzenie", "Rachunki"
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  allocations BudgetAllocation[]
  transactions BudgetTransaction[]
}

model BudgetAllocation {
  id            String         @id @default(cuid())
  month         Int            // 1-12
  year          Int
  categoryId    String
  plannedAmount Float          @default(0) // planowana kwota na kategorię (PLN)
  category      BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@unique([month, year, categoryId])
}

model BudgetTransaction {
  id         String         @id @default(cuid())
  date       DateTime       // data transakcji
  amount     Float          // dodatnia = przychód, ujemna = wydatek
  categoryId String
  memo       String?        @db.Text
  createdAt  DateTime       @default(now())
  category   BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

// =============================================================================
// MODUŁ BUDŻETU OSOBISTEGO (YNAB-style) – osobny od budżetu firmowego
// Obsługuje m.in. wydatki prywatne, konta, cele, harmonogramy
// =============================================================================

model PersonalBudget {
  id        String   @id @default(cuid())
  userId    String
  name      String   // np. "Osobisty", "Rodzinny", "Firma"
  currency  String   @default("PLN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts  PersonalAccount[]
  categoryGroups PersonalCategoryGroup[]
  transactions PersonalTransaction[]
  payees    PersonalPayee[]
  scheduledTransactions PersonalScheduledTransaction[]
}

model PersonalAccount {
  id          String   @id @default(cuid())
  budgetId    String
  name        String   // np. "Konto główne", "Gotówka", "Lokata"
  type        String   // ON_BUDGET: checking, savings, cash, debit | OFF_BUDGET: loan, investment, mortgage
  isOnBudget  Boolean  @default(true) // true = ON_BUDGET, false = OFF_BUDGET (tracking)
  balance     Float    @default(0)    // aktualne saldo (cache)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  budget      PersonalBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  transactions PersonalTransaction[]
  scheduledTransactions PersonalScheduledTransaction[]
}

model PersonalCategoryGroup {
  id          String   @id @default(cuid())
  budgetId    String
  name        String   // np. "Mieszkanie", "Jedzenie", "Wydatki prywatne"
  isPrivateExpenses Boolean @default(false) // true = grupa na wydatki prywatne (flaga do filtrów/raportów)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  budget      PersonalBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  categories  PersonalCategory[]
}

model PersonalCategory {
  id            String   @id @default(cuid())
  groupId       String
  name          String   // np. "Czynsz", "Zakupy", "Restauracje"
  sortOrder     Int      @default(0)
  isSystem      Boolean  @default(false) // true = "Do przydzielenia" (To Be Budgeted) – nie usuwać
  targetType    String?  // null | monthly_spending | savings | target_by_date
  targetAmount  Float?   // np. 1000 miesięcznie
  targetDate    DateTime? // dla target_by_date
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  group         PersonalCategoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  transactions  PersonalTransaction[]
  allocations   PersonalAllocation[]
  payeeCategory PersonalPayeeCategory[] @relation("PayeeCategory")
  scheduledTransactions PersonalScheduledTransaction[]
}

model PersonalAllocation {
  id         String   @id @default(cuid())
  categoryId String
  month      Int      // 1-12
  year       Int
  amount     Float    @default(0) // przydzielona kwota (budżet)
  createdAt  DateTime @default(now())
  category   PersonalCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@unique([categoryId, month, year])
}

model PersonalTransaction {
  id          String   @id @default(cuid())
  budgetId    String
  accountId   String
  date        DateTime
  payeeId     String?
  categoryId  String?
  amount      Float    // ujemna = wydatek, dodatnia = przychód/transfer
  memo        String?  @db.Text
  cleared     Boolean  @default(false) // zrekoncyliowane
  isPrivate   Boolean  @default(false) // wydatek prywatny (do raportów)
  scheduledTransactionId String?
  createdAt   DateTime @default(now())
  budget      PersonalBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  scheduledTransaction PersonalScheduledTransaction? @relation(fields: [scheduledTransactionId], references: [id], onDelete: SetNull)
  account     PersonalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  payee       PersonalPayee?  @relation(fields: [payeeId], references: [id], onDelete: SetNull)
  category    PersonalCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model PersonalPayee {
  id        String   @id @default(cuid())
  budgetId  String
  name      String   // np. "Lidl", "PGE", "Netflix"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  budget    PersonalBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  transactions PersonalTransaction[]
  defaultCategory PersonalPayeeCategory[] @relation("PayeeCategory")
  scheduledTransactions PersonalScheduledTransaction[]
}

model PersonalPayeeCategory {
  id         String   @id @default(cuid())
  payeeId    String   @unique
  categoryId String
  payee      PersonalPayee   @relation("PayeeCategory", fields: [payeeId], references: [id], onDelete: Cascade)
  category   PersonalCategory @relation("PayeeCategory", fields: [categoryId], references: [id], onDelete: Cascade)
}

model PersonalScheduledTransaction {
  id          String   @id @default(cuid())
  budgetId    String
  accountId   String
  payeeId     String?
  categoryId  String?
  amount      Float
  memo        String?  @db.Text
  frequency   String   // monthly | yearly | weekly
  nextDate    DateTime // następna data wystąpienia
  createdAt   DateTime @default(now())
  budget      PersonalBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account     PersonalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  payee       PersonalPayee?  @relation(fields: [payeeId], references: [id], onDelete: SetNull)
  category    PersonalCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions PersonalTransaction[]
}
