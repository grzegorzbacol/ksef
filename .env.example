# PostgreSQL (Coolify / Docker / lokalnie) – ustaw w Environment lub .env
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/NAZWA_BAZY?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ksef?schema=public"
NEXTAUTH_SECRET="change-me-in-production"

# Cron (Vercel) – opcjonalnie; jeśli ustawione, endpointy /api/cron/* (mail-fetch, ksef-fetch, itd.) wymagają nagłówka Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=""

# Tesla Scanner – powiadomienia Telegram o nowych autach w inventory
# TESLA_TELEGRAM_TOKEN=""
# TESLA_TELEGRAM_CHAT_ID=""
# TESLA_PROXY_URL="http://user:pass@proxy:port"  # opcjonalnie – przy HTTP 403
# TESLA_SCRAPINGBEE_KEY=""  # przy 403 – ScrapingBee omija Akamai (1000 darmowych requestów)

# KSEF (Krajowy System e-Faktur) – pobieranie i wysyłka faktur
# Token uzyskaj w portalu KSEF (np. https://ksef.mf.gov.pl). Środowisko demo: https://api-demo.ksef.mf.gov.pl
KSEF_API_URL="https://api.ksef.mf.gov.pl"
KSEF_TOKEN=""
# Opcjonalnie – ścieżki API (gdy różne od domyślnych):
# KSEF_QUERY_INVOICES_PATH="/v2/invoices/query/metadata"
# KSEF_SEND_INVOICE_PATH="/api/online/Invoice/Send"
